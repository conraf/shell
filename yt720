#!/bin/zsh
# ──────────────────────────────────────────────────────────────────────
# yt720 – prende SEMPRE 136+140 se esistono, altrimenti il migliore 720p
# ──────────────────────────────────────────────────────────────────────

yt-dlp "$@" \
  -f "136+140/136+bestaudio/bestvideo[height<=720][fps<=30][vcodec^=avc1]+bestaudio[ext=m4a]/bestvideo[height<=720]+bestaudio/best" \
  --merge-output-format mp4 \
  --no-quiet \
  --progress \
  --print $'after_move:\n✅ Download completato\n📁 %(filepath)s'
