#!/usr/bin/env zsh

# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
#  yt-playlist-mp3 вЂ” scarica audio da playlist
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

setopt nullglob

# в”Ђв”Ђ Colori e stili в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
BOLD=$'\e[1m'
DIM=$'\e[2m'
RESET=$'\e[0m'
GREEN=$'\e[32m'
YELLOW=$'\e[33m'
CYAN=$'\e[36m'
RED=$'\e[31m'
MAGENTA=$'\e[35m'

# в”Ђв”Ђ Banner в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo ""
echo "${CYAN}${BOLD}  рџЋ§  yt-playlist-mp3${RESET}"
echo "${DIM}  Scarica l'audio di una playlist YouTube in MP3 320k${RESET}"
echo ""

# в”Ђв”Ђ Controllo dipendenze в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
missing=()
for cmd in yt-dlp ffmpeg detox; do
  if ! command -v "$cmd" &>/dev/null; then
    missing+=("$cmd")
  fi
done

if [[ ${#missing[@]} -gt 0 ]]; then
  echo "${RED}вќЊ  Dipendenze mancanti: ${missing[*]}${RESET}"
  echo "${DIM}   Installa con: brew install ${missing[*]}${RESET}"
  echo ""
  exit 1
fi

# в”Ђв”Ђ Input URL в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo -n "${YELLOW}рџ”—  Incolla il link alla playlist YouTube: ${RESET}"
read PLAYLIST_URL

if [[ -z "$PLAYLIST_URL" ]]; then
  echo "${RED}вќЊ  Nessun URL inserito. Uscita.${RESET}"
  exit 1
fi

# в”Ђв”Ђ Cartella di destinazione в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
DEFAULT_DIR="$HOME/Music/yt-playlist-mp3/$(date '+%Y-%m-%d_%H-%M-%S')"
echo ""
echo -n "${YELLOW}рџ“Ѓ  Cartella di destinazione ${DIM}[invio = predefinita]${RESET}${YELLOW}: ${RESET}"
echo "${DIM}${DEFAULT_DIR}${RESET}"
echo -n "    > "
read CUSTOM_DIR

if [[ -z "$CUSTOM_DIR" ]]; then
  DOWNLOAD_DIR="$DEFAULT_DIR"
else
  DOWNLOAD_DIR="${CUSTOM_DIR/#\~/$HOME}"
fi

mkdir -p "$DOWNLOAD_DIR"

echo ""
echo "${CYAN}рџ“‚  Salvataggio in:${RESET} ${BOLD}$DOWNLOAD_DIR${RESET}"
echo ""
echo "${MAGENTA}в¬‡пёЏ   Download in corso...${RESET}"
echo ""

# в”Ђв”Ђ Download audio grezzo в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
yt-dlp \
  --format "bestaudio" \
  --output "$DOWNLOAD_DIR/%(title)s [%(id)s].%(ext)s" \
  --yes-playlist \
  --ignore-errors \
  --no-warnings \
  --progress \
  "$PLAYLIST_URL"

downloaded=("$DOWNLOAD_DIR"/*)
if [[ ${#downloaded[@]} -eq 0 ]]; then
  echo ""
  echo "${RED}вќЊ  Nessun file scaricato. Controlla l'URL e riprova.${RESET}"
  exit 1
fi

echo ""
echo "${MAGENTA}рџ”§  Pulizia ID YouTube dai nomi file...${RESET}"

# в”Ђв”Ђ Rimozione ID YouTube PRIMA del detox в”Ђв”Ђв”Ђв”Ђв”Ђ
# yt-dlp aggiunge sempre " [xxxxxxxxxxx]" alla fine del titolo
# (spazio + parentesi quadre + 11 char alfanumerici)
# Lo rimuoviamo qui mentre il nome ГЁ ancora integro,
# prima che detox trasformi [ ] in _ rendendo il pattern ambiguo
for f in "$DOWNLOAD_DIR"/*; do
  [[ -f "$f" ]] || continue
  dir="${f:h}"
  base="${f:t}"
  ext="${base:e}"
  name="${base:r}"

  # Rimuove il suffisso " [ID11chars]" вЂ” ID YouTube: lettere, cifre, - e _
  # Usa parameter expansion con regex (zsh 5+)
  new_name="${name% \[[A-Za-z0-9_-][A-Za-z0-9_-][A-Za-z0-9_-][A-Za-z0-9_-][A-Za-z0-9_-][A-Za-z0-9_-][A-Za-z0-9_-][A-Za-z0-9_-][A-Za-z0-9_-][A-Za-z0-9_-][A-Za-z0-9_-]\]}"

  if [[ "$new_name" != "$name" ]]; then
    mv "$f" "$dir/${new_name}.${ext}" 2>/dev/null
  fi
done

echo "${MAGENTA}рџ”§  Applicazione detox ai nomi file...${RESET}"

# в”Ђв”Ђ Detox в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
detox "$DOWNLOAD_DIR"/* 2>/dev/null

echo "${MAGENTA}рџЋ›пёЏ   Conversione in MP3 320kbps...${RESET}"
echo ""

# в”Ђв”Ђ Conversione in MP3 320k con ffmpeg в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
converted=0
errors=0

for f in "$DOWNLOAD_DIR"/*; do
  [[ -f "$f" ]] || continue
  ext_lower="${(L)${f:e}}"

  if [[ "$ext_lower" == "mp3" ]]; then
    echo "   рџЋ§  ${DIM}${f:t}${RESET} в†’ ${CYAN}giГ  MP3, skip${RESET}"
    (( converted++ ))
    continue
  fi

  out="${f:r}.mp3"
  echo -n "   рџЋ§  ${DIM}${f:t}${RESET} в†’ "

  ffmpeg -i "$f" -vn -ab 320k -ar 44100 -y "$out" -loglevel error 2>/dev/null

  if [[ $? -eq 0 ]]; then
    rm -f "$f"
    echo "${GREEN}вњ“ MP3${RESET}"
    (( converted++ ))
  else
    echo "${RED}вњ— errore conversione${RESET}"
    (( errors++ ))
  fi
done

# в”Ђв”Ђ Riepilogo в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
total=$(print -l "$DOWNLOAD_DIR"/*.mp3(N) | wc -l | tr -d ' ')

echo ""
echo "${GREEN}${BOLD}вњ…  Completato!${RESET}"
echo ""
echo "   рџЋ§  File MP3:     ${BOLD}${total}${RESET}"
[[ $errors -gt 0 ]] && echo "   вљ пёЏ   Errori:       ${YELLOW}${errors}${RESET}"
echo ""
echo "${CYAN}рџ“‚  Path cartella:${RESET}"
echo "    ${BOLD}$DOWNLOAD_DIR${RESET}"
echo ""
